# ===========================================
# DS Market Kit — 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# ===========================================

# --- 基础配置 ---
# 本地开发或生产部署地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- JWT 密钥（务必修改！）---
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_your_random_64_byte_hex_string

# --- Stripe 支付 ---
# 从 https://dashboard.stripe.com/apikeys 获取
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# 从 Stripe Dashboard → Webhooks 获取
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# --- 支付宝支付（可选）---
# 从 https://open.alipay.com 获取
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_private_key_here
ALIPAY_PUBLIC_KEY=your_alipay_public_key_here
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/webhooks/alipay

# --- 微信支付（可选）---
# 从 https://pay.weixin.qq.com 获取
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_api_key
WECHAT_NOTIFY_URL=https://yourdomain.com/api/webhooks/wechat

# --- 数据库（开发环境使用 SQLite 无需配置）---
# 生产环境推荐 PostgreSQL，修改 prisma/schema.prisma 中的 provider
DATABASE_URL="file:./dev.db"
