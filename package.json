{
  "name": "ds-market-kit",
  "version": "1.0.0",
  "description": "数字产品商店启动套件 — Next.js 全栈电商模板，集成 Stripe/支付宝/微信支付",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
